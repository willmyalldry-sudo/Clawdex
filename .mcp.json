    },
    "pipedream-bouncer-email-validation": {
      "type": "http",
      "url": "https://mcp.pipedream.com/app/bouncer"
    },
    "meilisearch": {
      "command": "uvx",
      "args": ["-n", "meilisearch-mcp"]
    },
